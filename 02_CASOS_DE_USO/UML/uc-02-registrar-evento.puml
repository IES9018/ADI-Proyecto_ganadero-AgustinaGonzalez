@startuml
left to right direction

actor PersonalCampo
actor Productor

rectangle "Registro de Eventos Sanitarios" {

  usecase "Seleccionar Animal" as UC1
  usecase "Registrar Vacunación" as UC2
  usecase "Registrar Tratamiento" as UC3
  usecase "Registrar Movimiento" as UC4
  usecase "Validar Datos del Evento" as UC5
  usecase "Guardar Evento" as UC6
}

PersonalCampo --> UC2
PersonalCampo --> UC3
PersonalCampo --> UC4

UC2 ..> UC1 : <<include>>
UC3 ..> UC1 : <<include>>
UC4 ..> UC1 : <<include>>

UC2 ..> UC5 : <<include>>
UC3 ..> UC5 : <<include>>
UC4 ..> UC5 : <<include>>

UC5 ..> UC6 : <<include>>

Productor --> UC1

@enduml