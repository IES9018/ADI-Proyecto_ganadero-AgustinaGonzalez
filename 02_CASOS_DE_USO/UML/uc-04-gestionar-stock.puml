@startuml
left to right direction

actor Productor
actor PersonalCampo

rectangle "Gestión de Stock" {

  usecase "Registrar Insumo" as UC1
  usecase "Actualizar Cantidad" as UC2
  usecase "Consultar Stock" as UC3
  usecase "Registrar Consumo" as UC4
  usecase "Validar Stock Mínimo" as UC5
  usecase "Generar Alerta de Stock Bajo" as UC6
}

Productor --> UC1
Productor --> UC3

PersonalCampo --> UC2
PersonalCampo --> UC4

UC2 ..> UC5 : <<include>>
UC4 ..> UC5 : <<include>>

UC5 ..> UC6 : <<extend>>

@enduml