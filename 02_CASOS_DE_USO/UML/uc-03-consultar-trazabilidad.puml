@startuml
left to right direction

actor Productor
actor PersonalCampo

rectangle "Consulta de Trazabilidad" {

  usecase "Buscar Animal por ID" as UC1
  usecase "Ver Historial de Eventos" as UC2
  usecase "Filtrar por Tipo de Evento" as UC3
  usecase "Ver Estado Sanitario Actual" as UC4
  usecase "Generar Vista Histórica" as UC5
}

Productor --> UC1
Productor --> UC2
Productor --> UC3
Productor --> UC4
Productor --> UC5

PersonalCampo --> UC1
PersonalCampo --> UC2

UC2 ..> UC1 : <<include>>
UC5 ..> UC2 : <<include>>

@enduml